{
  "name": "PlanetGen2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "export:lobby": "node scripts/export-lobby-scene.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@iwsdk/core": "0.3.1",
    "@polygon-streaming/web-player-threejs": "^2.8.1",
    "ammo.js": "^0.0.10",
    "three": "npm:super-three@0.181.0"
  },
  "devDependencies": {
    "@felixtz/iwsdk-rag-mcp": "^0.3.1",
    "@iwsdk/vite-plugin-dev": "0.3.1",
    "@iwsdk/vite-plugin-uikitml": "0.3.1",
    "@meta-quest/hzdb": "^1.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/three": "*",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.1.4",
    "vite-plugin-mkcert": "^1.17.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
